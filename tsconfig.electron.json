{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "rootDir": "./src/electron",
    "outDir": "./dist_electron",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true
  },
  "include": ["src/electron/**/*.ts"]
}
